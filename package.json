{
  "name": "coderx_server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development node --watch ./src/main.js",
    "dev:socket": "NODE_ENV=development node --watch ./src/socket_server.js",
    "start": "NODE_ENV=production node ./src/main.js",
    "start:socket": "NODE_ENV=production node ./src/socket_server.js",
    "test:database:stage3": "node --test test/database-stage3.test.js",
    "test:migration:phase2": "node --test test/migration/phase2-utils.test.js",
    "test:migration:phase5": "node --test test/migration/article-read-parity.test.js test/migration/history-parity.test.js test/migration/comment-read-parity.test.js test/migration/comment-write-parity.test.js test/migration/collect-parity.test.js test/migration/user-auth-parity.test.js test/migration/file-meta-parity.test.js test/migration/clean-orphan-parity.test.js",
    "test:migration:hotspots": "node --test \"test/service/*.test.js\" \"test/tasks/*.test.js\" \"test/controller/*.test.js\"",
    "test:migration:regression": "pnpm run test:migration:phase2 && pnpm run test:database:stage3 && pnpm run test:migration:hotspots && pnpm run test:migration:phase5",
    "migration:phase2:verify": "node scripts/migration/phase2/verify-parity.js",
    "migration:phase2:bootstrap": "node scripts/migration/phase2/bootstrap-pg.js",
    "migration:phase5:article-read": "node scripts/migration/verify-article-read-parity.js",
    "migration:phase5:history": "node scripts/migration/verify-history-parity.js",
    "migration:phase5:comment-read": "node scripts/migration/verify-comment-read-parity.js",
    "migration:phase5:comment-write": "node scripts/migration/verify-comment-write-parity.js",
    "migration:phase5:collect": "node scripts/migration/verify-collect-parity.js",
    "migration:phase5:user-auth": "node scripts/migration/verify-user-auth-parity.js",
    "migration:phase5:file-meta": "node scripts/migration/verify-file-meta-parity.js",
    "migration:phase5:clean-orphan": "node scripts/migration/verify-clean-orphan-parity.js",
    "prettier": "prettier --write .",
    "update:prettier": "git fetch https://github.com/yangdanping/prettier_config_repo.git main && git checkout FETCH_HEAD -- .prettierrc .prettierignore"
  },
  "keywords": [],
  "author": "",
