    "jimp": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.4.1",
    "log4js": "^6.9.1",
    "markdown-it": "^14.1.1",
    "module-alias": "^2.3.4",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
